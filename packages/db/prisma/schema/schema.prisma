generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
}

enum ContentStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
}

enum TemplateCategory {
  BLOG
  SOCIAL
  AD
  EMAIL
  CUSTOM
}

model User {
  id        Int   @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectMembers   ProjectMember[]
  contents         Content[]       @relation("author")
  reviewedContents Content[]       @relation("reviewer")
  ownedProjects    Project[]       @relation("projectOwner")
}

model Project {
  id          Int   @id @default(autoincrement())
  name        String
  description String
  ownerId     Int
  createdAt   DateTime @default(now())

  owner          User            @relation("projectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  projectMembers ProjectMember[]
  templates      Template[]
  contents       Content[]

  @@index([ownerId])
}

model ProjectMember {
  id        Int   @id @default(autoincrement())
  userId    Int
  projectId Int
  role      UserRole

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model Template {
  id             Int           @id @default(autoincrement())
  name           String
  category       TemplateCategory
  promptTemplate String
  variables      Json
  projectId      Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contents Content[]

  @@index([projectId])
  @@index([projectId, category])
}

model Content {
  id              Int        @id @default(autoincrement())
  title           String
  body            String
  status          ContentStatus @default(DRAFT)
  rejectionReason String?
  templateId      Int?
  projectId       Int
  authorId        Int
  reviewerId      Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  author   User      @relation("author", fields: [authorId], references: [id], onDelete: Restrict)
  reviewer User?     @relation("reviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, status, createdAt])
  @@index([projectId, status, updatedAt])
  @@index([authorId])
  @@index([authorId, createdAt])
  @@index([reviewerId])
  @@index([templateId])
}
