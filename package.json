{
  "name": "contentforge",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next": "^16.2.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.5",
      "@prisma/client": "^7.8.0",
      "@orpc/server": "^1.13.14",
      "@orpc/client": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F @contentforge/web dev",
    "db:push": "turbo -F @contentforge/db db:push",
    "db:studio": "turbo -F @contentforge/db db:studio",
    "db:generate": "turbo -F @contentforge/db db:generate",
    "db:migrate": "turbo -F @contentforge/db db:migrate",
    "test": "turbo test",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@contentforge/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@contentforge/config": "workspace:*",
    "@types/node": "^22.13.14",
    "husky": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.8.0"
  },
  "packageManager": "bun@1.3.13"
}
